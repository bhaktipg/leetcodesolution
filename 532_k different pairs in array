class Solution:
    def findPairs(self, nums: List[int], k: int) -> int:
        c=0
        pairs=[]
        for i in range(len(nums)):
            for j in range(i+1,len(nums)):
                if (abs(nums[i]-nums[j])==k) and i!=j:
                      pair = sorted([nums[i], nums[j]])
                      if pair not in pairs:
                        pairs.append(pair)

        return len(pairs)