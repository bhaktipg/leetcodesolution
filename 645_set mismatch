class Solution:
    def findErrorNums(self, nums: List[int]) -> List[int]:
        total=len(nums)*(len(nums)+1)/2
        count=Counter(nums)
        s=0
        a=[]

        for key , value in count.items():
            if value==2:
                a.append(key)
                extra=key

        for i in range(len(nums)):
            s=s+nums[i]
    
        miss=total-(s-extra)
        a.append(int(miss))
        return a