import pandas as pd

def big_countries(world: pd.DataFrame) -> pd.DataFrame:
    result = []

    for index, row in world.iterrows():
        if row['area'] >= 3000000 or row['population'] >= 25000000:
            result.append([
                row['name'],
                row['population'],
                row['area']
            ])

    return pd.DataFrame(result, columns=['name', 'population', 'area'])