    def finalString(self, s: str) -> str:
        a=[]
        for i in range(len(s)):
            if s[i]=='i' and i==0:
                a.append(s[i])
                break
            elif s[i]is not 'i':
                a.append(s[i])
            else:
                a.reverse()
        res="".join(a)
        return res