class Solution:
    def isSameAfterReversals(self, num: int) -> bool:
        s=list(str(num))
        s1=s[::-1]
        for i in range(len(s1)):
            if s1[i] != '0':
                s1 = s1[i:]
                break
        s2=s1[::-1]
        s3= int("".join(map(str,s2)))
        print(s3)
    
        if s3==num:
            return True
        else:
            return False