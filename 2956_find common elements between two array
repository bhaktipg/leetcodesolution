class Solution:
    def findIntersectionValues(self, nums1: List[int], nums2: List[int]) -> List[int]:
        count1 = Counter(nums1)
        count2 = Counter(nums2)

        s1 = 0
        s2 = 0

        for key, value in count1.items():
            if key in count2:
                s1 += value

        for key, value in count2.items():
            if key in count1:
                s2 += value

        return [s1, s2]