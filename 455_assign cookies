class Solution:
    def findContentChildren(self, g: List[int], s: List[int]) -> int:
        c = 0
        s=sorted(s)
        g=sorted(g)
        i=0
        j=0

        a=0
        while i<len(g) and j<len(s):
            if s[j]>=g[i]:
                a=a+1
                i=1+i
                j=j+1
            else:
                j=j+1
        return a