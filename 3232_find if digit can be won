class Solution:
    def canAliceWin(self, nums: List[int]) -> bool:
        a=0
        b=0

        for i in range(len(nums)):
            if 0 <= nums[i] <= 9:
                a=a+nums[i]
            else:
                b=b+nums[i]

        if a>b or b>a:
            return True
        else:
            return False