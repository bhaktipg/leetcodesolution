class Solution:
    def smallerNumbersThanCurrent(self, nums: List[int]) -> List[int]:
        s=0
        a=[]

        for i in range(len(nums)):
            for j in range(len(nums)):
                if nums[i]> nums[j] and i!=j:
                    s=s+1
            a.append(s)
            s=0
        return a