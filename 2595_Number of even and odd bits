class Solution:
    def evenOddBit(self, n: int) -> List[int]:
        result=""
        a=0
        b=0
        re=[]


        while n>0:
            result= result+str(n%2)
            n=n//2
  
        for i in range(len(result)):
            if result[i]=='1':
                if i%2==0 or i==0:
                    a=a+1
                else:
                    b=b+1
            
        return [a,b]