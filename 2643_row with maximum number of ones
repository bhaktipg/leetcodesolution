class Solution:
    def rowAndMaximumOnes(self, mat: List[List[int]]) -> List[int]:
        s=0
        a=[]

        for i in range(len(mat)):
            for j in range(len(mat[i])):
                if mat[i][j]==1:
                    s=s+1
            a.append(s)
            s=0
        idx = a.index(max(a))
        value=a[idx]
        return [idx,value]
        