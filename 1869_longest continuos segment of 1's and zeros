class Solution:
    def checkZeroOnes(self, s: str) -> bool:
        s2=0
        s1=0
        a=[]
        b=[]

        for i in range(len(s)):
            if s[i]=='0':
                s1=0
                s2=s2+1
                a.append(s2)
            elif s[i]=='1':
                s2=0
                s1=1+s1
                b.append(s1)
            a.append(s2)
            b.append(s1)
        if max(b)>max(a):
            return True
        else :
            return False