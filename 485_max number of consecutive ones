class Solution:
    def findMaxConsecutiveOnes(self, nums: List[int]) -> int:
        s=0
        a=[]

        for i in range(len(nums)):
            if nums[i]==0:
                a.append(s)
                s=0
            elif nums[i]==1:
                s=s+1
            a.append(s)
        return max(a)
        