class Solution:
    def minimumAbsDifference(self, arr: List[int]) -> List[List[int]]:
        a= sorted(arr)

        first = float('inf')

        for i in range(len(arr) - 1):
            first = min(first, a[i + 1] - a[i])
        
        result = []
        for i in range(len(arr) - 1):
            if a[i + 1] - a[i] == first:
                result.append([a[i], a[i + 1]])

        return result